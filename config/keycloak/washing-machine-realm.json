{
  "realm": "${KEYCLOAK_REALM}",
  "enabled": true,
  "displayName": "Washing Machine",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "${OIDC_USER_ROLE_NAME}",
        "description": "Read-only API and MCP access"
      },
      {
        "name": "${OIDC_ADMIN_ROLE_NAME}",
        "description": "Administrative API access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "${OIDC_SWAGGER_CLIENT_ID}",
      "name": "${OIDC_SWAGGER_CLIENT_ID}",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:8000/oauth2-redirect",
        "http://api:8000/oauth2-redirect"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://api:8000"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "${KEYCLOAK_DEV_USER_USERNAME}",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_DEV_USER_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "${OIDC_USER_ROLE_NAME}"
      ]
    },
    {
      "username": "${KEYCLOAK_DEV_ADMIN_USERNAME}",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "${KEYCLOAK_DEV_ADMIN_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "${OIDC_USER_ROLE_NAME}",
        "${OIDC_ADMIN_ROLE_NAME}"
      ]
    }
  ]
}
