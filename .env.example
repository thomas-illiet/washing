APP_NAME=Metrics Collector
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/metrics_collector
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
SCHEDULER_TICK_SECONDS=60
APPLICATION_SYNC_TICK_SECONDS=3600
APPLICATION_SYNC_WINDOW_DAYS=5
APPLICATION_SYNC_BATCH_SIZE=0
APPLICATION_SYNC_RETRY_AFTER_SECONDS=3600
PROMETHEUS_API_ENABLED=true
PROMETHEUS_API_PATH=/metrics
CELERY_PROMETHEUS_ENABLED=true
CELERY_PROMETHEUS_PORT=9101
