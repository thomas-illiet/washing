# Copy this file to .env and adjust values for your environment.

# Application
APP_NAME=Washing Machine

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/metrics_collector
INTEGRATION_CONFIG_ENCRYPTION_KEY=8P2uXg4rqwH0TADaBrZEcD3xKhsR4HIX66vepQP9enM=

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_BEAT_SCHEDULE_PATH=/tmp/celerybeat-schedule
FLOWER_BASIC_AUTH=admin:change-me
FLOWER_COOKIE_SECRET=change-me-in-production

# Scheduler
SCHEDULER_TICK_SECONDS=60

# Application sync
# Set APPLICATION_SYNC_BATCH_SIZE to 0 to auto-calculate the batch size.
APPLICATION_SYNC_TICK_SECONDS=3600
APPLICATION_SYNC_WINDOW_DAYS=5
APPLICATION_SYNC_BATCH_SIZE=0
APPLICATION_SYNC_RETRY_AFTER_SECONDS=3600

# Prometheus API
PROMETHEUS_API_ENABLED=true
PROMETHEUS_API_PATH=/metrics

# Celery Prometheus exporter
CELERY_PROMETHEUS_ENABLED=true
CELERY_PROMETHEUS_PORT=9101

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
