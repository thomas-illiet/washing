# Copy this file to .env and adjust values for your environment.

# Application
APP_NAME=Washing Machine
APP_ENV=prod
MCP_API_BASE_URL=http://api:8000
MCP_API_TIMEOUT_SECONDS=30

# OIDC
OIDC_ENABLED=true
OIDC_ISSUER_URL=http://localhost:8080/realms/washing-machine
OIDC_DISCOVERY_URL=http://keycloak:8080/realms/washing-machine/.well-known/openid-configuration
OIDC_JWKS_CACHE_TTL_SECONDS=300
OIDC_ROLE_CLAIM_PATHS=realm_access.roles,resource_access.*.roles,roles
# Replace these defaults if your IdP uses different role names.
OIDC_USER_ROLE_NAME=user
OIDC_ADMIN_ROLE_NAME=admin
OIDC_SWAGGER_CLIENT_ID=washing-machine-swagger
OIDC_SWAGGER_USE_PKCE=true
OIDC_SWAGGER_SCOPES=openid profile email

# Local Keycloak realm import
KEYCLOAK_REALM=washing-machine
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_DEV_USER_PASSWORD=reader-change-me
KEYCLOAK_DEV_ADMIN_PASSWORD=platform-admin-change-me

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/washing_machine
DATABASE_SCHEMA=app
# Generate one with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATABASE_ENCRYPTION_KEY=REPLACE_ME_WITH_FERNET_KEY

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_EXECUTION_RETENTION_DAYS=90
APPLICATION_RETENTION_DAYS=15
MACHINE_RETENTION_DAYS=15
FLOWER_BASIC_AUTH=admin:change-me
FLOWER_COOKIE_SECRET=change-me-in-production

# Scheduler
SCHEDULER_TICK_SECONDS=60

# Application inventory sync
APPLICATION_INVENTORY_SYNC_TICK_SECONDS=3600

# Application metrics sync
# Set APPLICATION_METRICS_SYNC_BATCH_SIZE to 0 to auto-calculate the batch size.
APPLICATION_METRICS_SYNC_TICK_SECONDS=3600
APPLICATION_METRICS_SYNC_WINDOW_DAYS=5
APPLICATION_METRICS_SYNC_BATCH_SIZE=0
APPLICATION_METRICS_SYNC_RETRY_AFTER_SECONDS=3600

# Machine optimization
FLAVOR_OPTIMIZATION_WINDOW_SIZE=30
FLAVOR_OPTIMIZATION_MIN_CPU=1
FLAVOR_OPTIMIZATION_MAX_CPU=64
FLAVOR_OPTIMIZATION_MIN_RAM_MB=2048
FLAVOR_OPTIMIZATION_MAX_RAM_MB=262144

# Prometheus API
PROMETHEUS_API_ENABLED=true
PROMETHEUS_API_PATH=/metrics

# Celery Prometheus exporter
CELERY_PROMETHEUS_ENABLED=true
CELERY_PROMETHEUS_PORT=9101

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
